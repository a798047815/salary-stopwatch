{
  "appId": "com.fishingtoucher.app",
  "appName": "摸鱼赚钱",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#488AFF",
      "sound": "beep.wav"
    }
  },
  "server": {
    "allowNavigation": ["*"]
  },
  "ios": {
    "contentInset": "always"
  },
  "android": {
    "allowMixedContent": true,
    "useLegacyBridge": false
  }
}