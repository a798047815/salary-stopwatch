/* pages/stats/stats.wxss */
page {
  background: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.stat-card {
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  color: white;
}

.stat-card.today {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
}

.stat-card.week {
  background: linear-gradient(135deg, #2196F3, #03A9F4);
}

.stat-card.month {
  background: linear-gradient(135deg, #9C27B0, #E91E63);
}

.stat-card.streak {
  background: linear-gradient(135deg, #FF9800, #FFC107);
}

.stat-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 60rpx;
  font-weight: bold;
}

.stat-date {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 10rpx;
}

.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.achievements {
  display: flex;
  flex-direction: column;
}

.achievement-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.achievement-item:last-child {
  border-bottom: none;
}

.achievement-item.locked {
  opacity: 0.4;
}

.achievement-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.achievement-info {
  flex: 1;
}

.achievement-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.achievement-desc {
  font-size: 24rpx;
  color: #999;
}

.achievement-check {
  font-size: 36rpx;
  color: #4CAF50;
  font-weight: bold;
}